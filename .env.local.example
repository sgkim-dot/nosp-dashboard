# NOSP 대시보드 자동화 스크립트 환경변수
# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 값을 채우세요.
# .env.local 은 git ignore 되어 있어 commit 되지 않습니다.

# ──────────────────────────────────────────────────────────
# Notion 사용자 가이드 동기화 (scripts/sync-user-guide-to-notion.mjs)
# ──────────────────────────────────────────────────────────
# Internal Integration Secret (https://www.notion.so/profile/integrations 에서 발급)
NOTION_TOKEN=ntn_여기에_실제_토큰_붙여넣기

# 대시보드 사용자 가이드 페이지 ID (Notion URL의 마지막 32자 hex)
# 예: https://app.notion.com/p/26a5e014a2948014960dfc5488f9bea0
#     →  NOTION_USER_GUIDE_PAGE_ID=26a5e014a2948014960dfc5488f9bea0
NOTION_USER_GUIDE_PAGE_ID=26a5e014a2948014960dfc5488f9bea0
